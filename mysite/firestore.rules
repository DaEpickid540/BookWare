rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == "admin";
    }

    function isTeacher() {
      return isSignedIn() && userRole() == "teacher";
    }

    function isStudent() {
      return isSignedIn() && userRole() == "student";
    }

    function isBanned() {
      let u = get(/databases/$(database)/documents/users/$(uid())).data;
      return u.get("banned", false) == true &&
        (u.get("banExpiry", null) == null ||
         u.banExpiry > request.time);
    }

    function notBanned() {
      return !isBanned();
    }

    // NOTE: Students are ordinary Google accounts (any gmail, etc.), so we
    // cannot restrict reads to a school domain without locking students out.
    // This intentionally means "any authenticated user". Do NOT store secrets
    // in documents guarded only by allowedEmail() — teacher docs, for example,
    // are a public directory (name/email/library visibility) by design.
    function allowedEmail() {
      return isSignedIn();
    }

    // Hardcoded admin allowlist — MUST stay in sync with public/js/config.js.
    // Gmail ignores dots, so both spellings of the first address are listed.
    function adminEmailList() {
      return ["sarvin.sukhe@gmail.com", "sarvinsukhe@gmail.com", "daepickid540@gmail.com"];
    }

    function emailLower() {
      return request.auth.token.email.lower();
    }

    function isAdminEmail() {
      return isSignedIn() && emailLower() in adminEmailList();
    }

    // Teacher-eligible email: the school's Google Workspace domain, or an
    // allowlisted admin. This is the server-side backstop for the invite-only
    // teacher flow — even with direct SDK calls, an outside account can never
    // give itself the teacher role.
    function isSchoolOrAdminEmail() {
      return isSignedIn() &&
        (emailLower().matches('.*@masonohioschools[.]com') || emailLower() in adminEmailList());
    }

    // True when an admin pre-registered this email via "Add User" with the
    // given role. auth.js provisions the account BEFORE deleting the
    // pendingUsers record, so this lookup still sees it at create time.
    // (Doc IDs there are the email lowercased with dots replaced by "_".)
    function hasPendingRole(role) {
      let key = emailLower().replace('[.]', '_');
      return exists(/databases/$(database)/documents/pendingUsers/$(key)) &&
        get(/databases/$(database)/documents/pendingUsers/$(key)).data.role == role;
    }

    // ── users/{uid} ────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Teachers get directory reads: the temp-ban flow looks a student up by
      // email and lists their own active bans, which requires querying this
      // collection. Students may only read their own record.
      allow read: if isSignedIn() && (uid() == userId || isTeacher() || isAdmin());

      // Role assignment is the security boundary and is enforced HERE, not in
      // client code:
      //   - anyone with a Google account may self-provision as a student
      //   - only allowlisted admin emails may self-provision as admin
      //   - teacher accounts require a school-domain (or admin) email, or an
      //     admin pre-registration in pendingUsers
      //   - admins may provision accounts for other people (access-request
      //     approval creates the user/teacher docs on the requester's behalf)
      allow create: if isAdmin() ||
        (isSignedIn() && uid() == userId &&
         request.resource.data.banned == false &&
         (request.resource.data.role == "student" ||
          (request.resource.data.role == "admin" && isAdminEmail()) ||
          (request.resource.data.role == "teacher" &&
           (isSchoolOrAdminEmail() || hasPendingRole("teacher")))));

      allow update: if isAdmin() ||
        // Allowlisted admin emails may self-promote (role only, never ban fields)
        (isSignedIn() && uid() == userId && isAdminEmail() &&
         request.resource.data.role == "admin" &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(["banned", "banExpiry", "banReason", "bannedBy", "bannedAt"])) ||
        // Teachers may temp-ban / unban STUDENTS only. A ban must carry a
        // non-null banExpiry (permanent bans stay admin-only), and the write
        // may touch nothing but the ban fields.
        (isTeacher() && resource.data.role == "student" &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(["banned", "banExpiry", "banReason", "bannedBy", "bannedAt"]) &&
         (request.resource.data.banned == false ||
          request.resource.data.banExpiry != null)) ||
        // Everyone else: own doc only, never role or ban fields
        (isSignedIn() && uid() == userId &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(["role", "banned", "banExpiry", "banReason", "bannedBy", "bannedAt"]));

      allow delete: if isAdmin();
    }

    // ── students/{uid} ─────────────────────────────────────────────────────────
    match /students/{studentId} {
      allow read: if isSignedIn() &&
        (uid() == studentId || isTeacher() || isAdmin());

      allow create: if isSignedIn() && uid() == studentId && allowedEmail();
      allow update: if (isSignedIn() && uid() == studentId && notBanned() &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(["banned", "banExpiry", "banReason"])) ||
        isTeacher() || isAdmin();

      allow delete: if isAdmin();

      match /recommendations/{recId} {
        // A student's recommendations are private to them, their teachers, and
        // admins — not readable by arbitrary signed-in peers.
        allow read: if isSignedIn() &&
          (uid() == studentId || isTeacher() || isAdmin());
        allow write: if isSignedIn() && uid() == studentId && notBanned();
      }
    }

    // ── teachers/{uid} ─────────────────────────────────────────────────────────
    match /teachers/{teacherId} {
      allow read: if isSignedIn() && allowedEmail();

      // getAfter (not get) so this works inside the invite-claim transaction,
      // where users/{uid} is created in the SAME transaction as this doc —
      // a plain get() would see pre-transaction state (no users doc) and
      // reject every invite claim. Admins may create teacher docs for other
      // people (access-request approval).
      allow create: if isAdmin() ||
        (isSignedIn() && uid() == teacherId &&
         getAfter(/databases/$(database)/documents/users/$(uid())).data.role in ["teacher", "admin"]);
      allow update: if (isSignedIn() && uid() == teacherId && isTeacher()) ||
        isAdmin();
      allow delete: if isAdmin();

      // ── teachers/{uid}/books/{bookId} ────────────────────────────────────
      match /books/{bookId} {
        allow read: if isAdmin() ||
          (isSignedIn() && uid() == teacherId && isTeacher()) ||
          (isSignedIn() && allowedEmail() &&
            (get(/databases/$(database)/documents/teachers/$(teacherId)).data.get("libraryPublic", false) == true ||
             exists(/databases/$(database)/documents/teachers/$(teacherId)/students/$(uid()))));

        allow create: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();
        allow delete: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();

        allow update: if isAdmin() ||
          (isSignedIn() && uid() == teacherId && isTeacher()) ||
          (isSignedIn() && isStudent() && notBanned() &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["status", "checkedOutBy", "checkedOutAt",
                       "dueDate", "checkedOutCount"]) &&
           (get(/databases/$(database)/documents/teachers/$(teacherId)).data.get("libraryPublic", false) == true ||
            exists(/databases/$(database)/documents/teachers/$(teacherId)/students/$(uid()))));
      }

      // ── teachers/{uid}/history/{histId} ─────────────────────────────────
      match /history/{histId} {
        allow read: if isSignedIn() &&
          (uid() == teacherId || isAdmin() ||
           (isStudent() && resource.data.studentId == uid()));
        allow create: if isSignedIn() && isStudent() && notBanned();
        allow update: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();
        allow delete: if isAdmin();
      }

      // ── teachers/{uid}/requests/{reqId} ─────────────────────────────────
      // Rental request/approval workflow
      match /requests/{reqId} {
        // Teacher reads all requests; students read only their own; admins read all
        allow read: if isSignedIn() &&
          (uid() == teacherId || isAdmin() ||
           (isStudent() && resource.data.studentId == uid()));

        // Students can create requests for enrolled or public libraries
        allow create: if isSignedIn() && isStudent() && notBanned() &&
          request.resource.data.studentId == uid() &&
          request.resource.data.status == "pending" &&
          (get(/databases/$(database)/documents/teachers/$(teacherId)).data.get("libraryPublic", false) == true ||
           exists(/databases/$(database)/documents/teachers/$(teacherId)/students/$(uid())));

        // Teachers can update (approve/deny); students cannot modify after creation
        allow update: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();

        allow delete: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();
      }

      // ── teachers/{uid}/classes/{classId} ────────────────────────────────
      match /classes/{classId} {
        allow read: if isSignedIn() && allowedEmail();
        allow write: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();

        match /students/{sid} {
          allow read: if isSignedIn() &&
            (uid() == teacherId || uid() == sid || isAdmin());
          allow create: if isSignedIn() &&
            (uid() == sid || uid() == teacherId) && allowedEmail();
          allow delete: if isSignedIn() &&
            (uid() == teacherId || uid() == sid || isAdmin());
          allow update: if isAdmin();
        }
      }

      // ── teachers/{uid}/recommendations/{recId} ──────────────────────────
      match /recommendations/{recId} {
        allow read: if isSignedIn() && allowedEmail();
        allow write: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();
      }

      // ── Legacy flat roster (teachers/{uid}/students/{sid}) ───────────────
      match /students/{sid} {
        allow read: if isSignedIn() &&
          (uid() == teacherId || uid() == sid || isAdmin());
        allow create: if isSignedIn() &&
          (uid() == sid || uid() == teacherId) && allowedEmail();
        allow delete: if isSignedIn() &&
          (uid() == teacherId || uid() == sid || isAdmin());
        allow update: if isAdmin();
      }
    }

    // ── invites/{token} ────────────────────────────────────────────────────────
    match /invites/{token} {
      // Single-doc reads are open (claim page validates token before sign-in)
      allow get: if true;
      // Only authenticated teachers/admins may query the collection
      allow list: if isSignedIn() && (isTeacher() || isAdmin());

      // Admin or teacher with canInvite may create
      allow create: if isSignedIn() &&
        (isAdmin() ||
         (isTeacher() &&
          get(/databases/$(database)/documents/teachers/$(uid())).data.get("canInvite", false) == true)) &&
        request.resource.data.keys().hasAll(["recipientEmail", "used", "expiresAt", "createdBy"]) &&
        request.resource.data.used == false;

      // Three distinct update paths:
      // 1. Admin can change anything
      // 2. Creator can revoke their own invite
      // 3. Claim flow — recipient (or anyone for open invites) marks as used
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == resource.data.createdBy &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(["revoked", "revokedAt", "revokedBy"])) ||
        (request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(["used", "claimedBy", "claimedAt"]) &&
         request.resource.data.used == true &&
         resource.data.used == false &&
         resource.data.get("revoked", false) == false &&
         (resource.data.get("recipientEmail", "") == "" ||
          request.auth.token.email.lower() == resource.data.recipientEmail.lower()))
      );

      allow delete: if isAdmin();
    }

    // ── accessRequests/{uid} ──────────────────────────────────────────────────────
    // Users who want teacher access submit a request here; admins approve or deny.
    match /accessRequests/{reqId} {
      // Requester and admins can read (live status updates on teacher-access.html)
      allow read: if isSignedIn() && (uid() == reqId || isAdmin());

      // Requester creates their own request (must be pending, cannot self-promote)
      allow create: if isSignedIn() && uid() == reqId &&
        request.resource.data.status == "pending" &&
        request.resource.data.keys().hasAll(["name", "email", "requestedAt", "status"]);

      // Admin approves/denies; requester can re-submit by resetting to pending
      allow update: if isAdmin() ||
        (isSignedIn() && uid() == reqId &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(["requestedAt", "status", "name", "email", "photoURL"]) &&
         request.resource.data.status == "pending");

      // Admin or the requester themselves can delete (withdraw request)
      allow delete: if isAdmin() || (isSignedIn() && uid() == reqId);
    }

    // ── pendingUsers/{emailKey} — admin-pre-registered accounts ──────────────────
    // Admin creates these via "Add User". On first sign-in the matching user reads
    // their own record (to learn their assigned role) and deletes it once claimed.
    match /pendingUsers/{emailKey} {
      // A signed-in user may only read the record that belongs to their own
      // email — prevents enumerating who has been pre-registered and with what
      // role. (The doc stores the email lowercased; auth.js looks up its own.)
      allow get:    if isSignedIn() &&
        request.auth.token.email.lower() == resource.data.email;
      allow list:   if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() ||
        (isSignedIn() && request.auth.token.email.lower() == resource.data.email);
    }

    // ── admin/settings ─────────────────────────────────────────────────────────
    // Read is open to any signed-in user because the student/teacher portals read
    // `maintenanceMode` at load to gate access. Only non-sensitive operational
    // flags (maintenanceMode, sessionEpoch) live here — never user PII or ban lists.
    match /admin/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── notifications (future FCM) ─────────────────────────────────────────────
    match /notifications/{userId}/{document=**} {
      allow read: if isSignedIn() && uid() == userId;
      allow write: if isAdmin() || isTeacher();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // SHARED DEFAULT DB — other school-suite apps. Namespaced so they never touch
    // BookWare's collections. This file is the authoritative ruleset for the
    // shared default database; School-Map and opensched must NOT deploy their own.
    // ═══════════════════════════════════════════════════════════════════════════

    // ── mason-navigator: shared map routes (public, append-only) ───────────────
    match /routes/{id} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // ── opensched: flex-time scheduling. Its users live under os_users/ to avoid
    //    colliding with BookWare's users/. ──────────────────────────────────────
    function osUserRole() {
      return get(/databases/$(database)/documents/os_users/$(uid())).data.role;
    }
    function isOsAdmin() {
      return isSignedIn() && osUserRole() == 'admin';
    }
    function isOsTeacher() {
      return isSignedIn() && osUserRole() == 'teacher';
    }

    // Role is the security boundary here, same principle as BookWare's own
    // users/{uid} above: self-serve student is open, self-serve admin requires
    // an allowlisted email, and "teacher" can ONLY be granted by an existing
    // os admin (approving an os_teacherRequests doc) — never by the account itself.
    match /os_users/{osUid} {
      allow read: if isSignedIn() && (uid() == osUid || isOsAdmin() || isOsTeacher());

      allow create: if isSignedIn() && uid() == osUid &&
        (request.resource.data.role == null || request.resource.data.role == 'student');

      allow update: if isOsAdmin() ||
        // Allowlisted admin emails may freely rewrite their OWN doc (including
        // role) regardless of what role is currently stored — this is what lets
        // e.g. sarvin.sukhe@gmail.com move between Student/Teacher/Admin without
        // ever getting stuck, since isOsAdmin() alone only fires once role is
        // already 'admin'.
        (isSignedIn() && uid() == osUid && isAdminEmail()) ||
        (isSignedIn() && uid() == osUid && resource.data.role == null &&
         request.resource.data.role == 'student' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role'])) ||
        // Teacher invite claim: self-serve "teacher" is allowed ONLY alongside a
        // same-transaction os_invites write that marks that exact token used by
        // this uid — see os_invites/{token} below and lib/invites.ts.
        (isSignedIn() && uid() == osUid &&
         request.resource.data.role == 'teacher' &&
         request.resource.data.get('lastInviteToken', '') is string &&
         request.resource.data.lastInviteToken != '' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'lastInviteToken']) &&
         getAfter(/databases/$(database)/documents/os_invites/$(request.resource.data.lastInviteToken)).data.claimedBy == uid() &&
         getAfter(/databases/$(database)/documents/os_invites/$(request.resource.data.lastInviteToken)).data.used == true) ||
        (isSignedIn() && uid() == osUid &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));

      allow delete: if isOsAdmin();

      match /mySignups/{occId} {
        allow read, write: if isSignedIn() && uid() == osUid;
      }
    }

    // ── opensched: admin-generated teacher invite links / QR codes ─────────────
    match /os_invites/{token} {
      allow get: if isSignedIn();
      allow list: if isOsAdmin();
      allow create: if isOsAdmin();
      // Claim: any signed-in user may mark an unused, unexpired invite as used by
      // themselves — paired in the same transaction with the os_users role grant above.
      allow update: if isSignedIn() && resource.data.used == false &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'claimedBy', 'claimedAt']) &&
        request.resource.data.used == true &&
        request.resource.data.claimedBy == uid() &&
        (resource.data.expiresAt == null || resource.data.expiresAt > request.time.toMillis());
      allow delete: if isOsAdmin();
    }

    // ── opensched: teacher-portal sign-ins awaiting admin approval ─────────────
    match /os_teacherRequests/{reqUid} {
      allow read: if isSignedIn() && (uid() == reqUid || isOsAdmin());
      allow create: if isSignedIn() && uid() == reqUid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.keys().hasAll(['uid', 'name', 'email', 'requestedAt', 'status']);
      allow update: if isOsAdmin() ||
        (isSignedIn() && uid() == reqUid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['requestedAt', 'status']) &&
         request.resource.data.status == 'pending');
      allow delete: if isOsAdmin() || (isSignedIn() && uid() == reqUid);
    }

    // ── opensched: admin-configurable scheduling policy (singleton doc) ────────
    match /os_settings/{doc} {
      allow read: if isSignedIn();
      allow write: if isOsAdmin();
    }

    // ── opensched: per-teacher-per-date hosting opt-out ─────────────────────────
    match /os_hostingStatus/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.resource.data.teacherId == uid();
      allow delete: if isOsAdmin();
    }

    match /sessionTemplates/{templateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.teacherId == uid()
                    && get(/databases/$(database)/documents/os_users/$(uid())).data.role == 'teacher';
      allow update, delete: if isSignedIn() && resource.data.teacherId == uid();
    }

    match /occurrences/{occId} {
      allow read: if isSignedIn();
      // Two ways to create: the normal template-derived occurrence (only the
      // owning teacher, and never flagged as a custom event), or an
      // admin-authored one-off "custom event" (opensched Custom Events, no
      // backing sessionTemplate) — see lib/customEvents.ts. The ordinary
      // branch pins BOTH that the caller IS the template's teacher (not just
      // that the claimed teacherId matches some template) and that
      // isCustomEvent isn't smuggled in on a non-admin write.
      allow create: if isSignedIn() && request.resource.data.signupCount == 0 &&
                    (
                      (isOsAdmin() && request.resource.data.isCustomEvent == true) ||
                      (request.resource.data.get('isCustomEvent', false) == false &&
                       uid() == request.resource.data.teacherId &&
                       request.resource.data.teacherId ==
                         get(/databases/$(database)/documents/sessionTemplates/$(request.resource.data.templateId)).data.teacherId)
                    );
      // signupCount may only move in lockstep with the CALLER's own roster
      // entry appearing/disappearing in the same transaction (see
      // signups/{sUid} below) — this is what actually enforces capacity and
      // stops anyone from inflating/deflating another occurrence's count.
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['signupCount'])
                    && request.resource.data.signupCount <= resource.data.capacity
                    && request.resource.data.signupCount >= 0
                    && (
                      (request.resource.data.signupCount == resource.data.signupCount + 1 &&
                       !exists(/databases/$(database)/documents/occurrences/$(occId)/signups/$(uid())) &&
                       existsAfter(/databases/$(database)/documents/occurrences/$(occId)/signups/$(uid()))) ||
                      (request.resource.data.signupCount == resource.data.signupCount - 1 &&
                       exists(/databases/$(database)/documents/occurrences/$(occId)/signups/$(uid())) &&
                       !existsAfter(/databases/$(database)/documents/occurrences/$(occId)/signups/$(uid())))
                    );
      allow delete: if isOsAdmin() && resource.data.isCustomEvent == true;
      match /signups/{sUid} {
        allow read: if isSignedIn();
        // Mirror image of the occurrences update rule above: a roster entry
        // may only be created/deleted alongside the matching signupCount
        // move on its parent, so the two can never drift apart.
        allow create: if isSignedIn() && uid() == sUid &&
          getAfter(/databases/$(database)/documents/occurrences/$(occId)).data.signupCount ==
            get(/databases/$(database)/documents/occurrences/$(occId)).data.signupCount + 1 &&
          getAfter(/databases/$(database)/documents/occurrences/$(occId)).data.signupCount <=
            get(/databases/$(database)/documents/occurrences/$(occId)).data.capacity;
        allow delete: if isSignedIn() && uid() == sUid &&
          getAfter(/databases/$(database)/documents/occurrences/$(occId)).data.signupCount ==
            get(/databases/$(database)/documents/occurrences/$(occId)).data.signupCount - 1;
        allow update: if false;
      }
    }

    // ── Deny everything else ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
