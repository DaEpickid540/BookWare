rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == "admin";
    }

    function isTeacher() {
      return isSignedIn() && userRole() == "teacher";
    }

    function isStudent() {
      return isSignedIn() && userRole() == "student";
    }

    function isBanned() {
      let u = get(/databases/$(database)/documents/users/$(uid())).data;
      return u.get("banned", false) == true &&
        (u.get("banExpiry", null) == null ||
         u.banExpiry > request.time);
    }

    function notBanned() {
      return !isBanned();
    }

    function allowedEmail() {
      return isSignedIn();
    }

    // ── users/{uid} ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (uid() == userId || isAdmin());

      allow create: if isSignedIn() &&
        uid() == userId &&
        allowedEmail() &&
        request.resource.data.role in ["student", "teacher", "admin"] &&
        request.resource.data.banned == false;

      allow update: if isAdmin() ||
        (isSignedIn() && uid() == userId &&
         request.auth.token.email.lower() in ["sarvin.sukhe@gmail.com", "sarvinsukhe@gmail.com", "daepickid540@gmail.com"] &&
         request.resource.data.role == "admin" &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(["banned", "banExpiry", "banReason", "bannedBy"])) ||
        (isSignedIn() && uid() == userId &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(["role", "banned", "banExpiry", "banReason", "bannedBy"]));

      allow delete: if isAdmin();
    }

    // ── students/{uid} ─────────────────────────────────────────────────────────
    match /students/{studentId} {
      allow read: if isSignedIn() &&
        (uid() == studentId || isTeacher() || isAdmin());

      allow create: if isSignedIn() && uid() == studentId && allowedEmail();
      allow update: if (isSignedIn() && uid() == studentId && notBanned() &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(["banned", "banExpiry", "banReason"])) ||
        isTeacher() || isAdmin();

      allow delete: if isAdmin();

      match /recommendations/{recId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && uid() == studentId && notBanned();
      }
    }

    // ── teachers/{uid} ─────────────────────────────────────────────────────────
    match /teachers/{teacherId} {
      allow read: if isSignedIn() && allowedEmail();

      allow create: if isSignedIn() && uid() == teacherId &&
        (userRole() == "teacher" || isAdmin()) && allowedEmail();
      allow update: if (isSignedIn() && uid() == teacherId && isTeacher()) ||
        isAdmin();
      allow delete: if isAdmin();

      // ── teachers/{uid}/books/{bookId} ────────────────────────────────────
      match /books/{bookId} {
        allow read: if isAdmin() ||
          (isSignedIn() && uid() == teacherId && isTeacher()) ||
          (isSignedIn() && allowedEmail() &&
            (get(/databases/$(database)/documents/teachers/$(teacherId)).data.get("libraryPublic", false) == true ||
             exists(/databases/$(database)/documents/teachers/$(teacherId)/students/$(uid()))));

        allow create: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();
        allow delete: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();

        allow update: if isAdmin() ||
          (isSignedIn() && uid() == teacherId && isTeacher()) ||
          (isSignedIn() && isStudent() && notBanned() &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["status", "checkedOutBy", "checkedOutAt",
                       "dueDate", "checkedOutCount"]) &&
           (get(/databases/$(database)/documents/teachers/$(teacherId)).data.get("libraryPublic", false) == true ||
            exists(/databases/$(database)/documents/teachers/$(teacherId)/students/$(uid()))));
      }

      // ── teachers/{uid}/history/{histId} ─────────────────────────────────
      match /history/{histId} {
        allow read: if isSignedIn() &&
          (uid() == teacherId || isAdmin() ||
           (isStudent() && resource.data.studentId == uid()));
        allow create: if isSignedIn() && isStudent() && notBanned();
        allow update: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();
        allow delete: if isAdmin();
      }

      // ── teachers/{uid}/requests/{reqId} ─────────────────────────────────
      // Rental request/approval workflow
      match /requests/{reqId} {
        // Teacher reads all requests; students read only their own; admins read all
        allow read: if isSignedIn() &&
          (uid() == teacherId || isAdmin() ||
           (isStudent() && resource.data.studentId == uid()));

        // Students can create requests for enrolled or public libraries
        allow create: if isSignedIn() && isStudent() && notBanned() &&
          request.resource.data.studentId == uid() &&
          request.resource.data.status == "pending" &&
          (get(/databases/$(database)/documents/teachers/$(teacherId)).data.get("libraryPublic", false) == true ||
           exists(/databases/$(database)/documents/teachers/$(teacherId)/students/$(uid())));

        // Teachers can update (approve/deny); students cannot modify after creation
        allow update: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();

        allow delete: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();
      }

      // ── teachers/{uid}/classes/{classId} ────────────────────────────────
      match /classes/{classId} {
        allow read: if isSignedIn() && allowedEmail();
        allow write: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();

        match /students/{sid} {
          allow read: if isSignedIn() &&
            (uid() == teacherId || uid() == sid || isAdmin());
          allow create: if isSignedIn() &&
            (uid() == sid || uid() == teacherId) && allowedEmail();
          allow delete: if isSignedIn() &&
            (uid() == teacherId || uid() == sid || isAdmin());
          allow update: if isAdmin();
        }
      }

      // ── teachers/{uid}/recommendations/{recId} ──────────────────────────
      match /recommendations/{recId} {
        allow read: if isSignedIn() && allowedEmail();
        allow write: if (isSignedIn() && uid() == teacherId && isTeacher()) || isAdmin();
      }

      // ── Legacy flat roster (teachers/{uid}/students/{sid}) ───────────────
      match /students/{sid} {
        allow read: if isSignedIn() &&
          (uid() == teacherId || uid() == sid || isAdmin());
        allow create: if isSignedIn() &&
          (uid() == sid || uid() == teacherId) && allowedEmail();
        allow delete: if isSignedIn() &&
          (uid() == teacherId || uid() == sid || isAdmin());
        allow update: if isAdmin();
      }
    }

    // ── invites/{token} ────────────────────────────────────────────────────────
    match /invites/{token} {
      // Single-doc reads are open (claim page validates token before sign-in)
      allow get: if true;
      // Only authenticated teachers/admins may query the collection
      allow list: if isSignedIn() && (isTeacher() || isAdmin());

      // Admin or teacher with canInvite may create
      allow create: if isSignedIn() &&
        (isAdmin() ||
         (isTeacher() &&
          get(/databases/$(database)/documents/teachers/$(uid())).data.get("canInvite", false) == true)) &&
        request.resource.data.keys().hasAll(["recipientEmail", "used", "expiresAt", "createdBy"]) &&
        request.resource.data.used == false;

      // Three distinct update paths:
      // 1. Admin can change anything
      // 2. Creator can revoke their own invite
      // 3. Claim flow — recipient (or anyone for open invites) marks as used
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == resource.data.createdBy &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(["revoked", "revokedAt", "revokedBy"])) ||
        (request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(["used", "claimedBy", "claimedAt"]) &&
         request.resource.data.used == true &&
         resource.data.used == false &&
         resource.data.get("revoked", false) == false &&
         (resource.data.get("recipientEmail", "") == "" ||
          request.auth.token.email.lower() == resource.data.recipientEmail.lower()))
      );

      allow delete: if isAdmin();
    }

    // ── accessRequests/{uid} ──────────────────────────────────────────────────────
    // Users who want teacher access submit a request here; admins approve or deny.
    match /accessRequests/{reqId} {
      // Requester and admins can read (live status updates on teacher-access.html)
      allow read: if isSignedIn() && (uid() == reqId || isAdmin());

      // Requester creates their own request (must be pending, cannot self-promote)
      allow create: if isSignedIn() && uid() == reqId &&
        request.resource.data.status == "pending" &&
        request.resource.data.keys().hasAll(["name", "email", "requestedAt", "status"]);

      // Admin approves/denies; requester can re-submit by resetting to pending
      allow update: if isAdmin() ||
        (isSignedIn() && uid() == reqId &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(["requestedAt", "status", "name", "email", "photoURL"]) &&
         request.resource.data.status == "pending");

      // Admin or the requester themselves can delete (withdraw request)
      allow delete: if isAdmin() || (isSignedIn() && uid() == reqId);
    }

    // ── pendingUsers/{emailKey} — admin-pre-registered accounts ──────────────────
    // Admin creates these via "Add User". On first sign-in the matching user reads
    // their own record (to learn their assigned role) and deletes it once claimed.
    match /pendingUsers/{emailKey} {
      allow get:    if isSignedIn();          // claim lookup by deterministic id
      allow list:   if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() ||
        (isSignedIn() && request.auth.token.email.lower() == resource.data.email);
    }

    // ── admin/settings ─────────────────────────────────────────────────────────
    match /admin/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── notifications (future FCM) ─────────────────────────────────────────────
    match /notifications/{userId}/{document=**} {
      allow read: if isSignedIn() && uid() == userId;
      allow write: if isAdmin() || isTeacher();
    }

    // ── Deny everything else ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
